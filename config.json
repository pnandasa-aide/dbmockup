{
    "database": {
        "driver_path": "path/to/jt400.jar",
        "driver_class": "com.ibm.as400.access.AS400JDBCDriver",
        "connection_url": "jdbc:as400://HOSTNAME;naming=sql;errors=full",
        "username": "YOUR_USERNAME",
        "password": "YOUR_PASSWORD",
        "schema": "YOUR_SCHEMA"
    },
    "files": {
        "schema_file": "schema_sample.json",
        "mockup_profile": "mockup_profile_sample.json"
    },
    "settings": {
        "batch_size": 1000,
        "log_level": "INFO"
    }
}
